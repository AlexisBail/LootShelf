{# templates/shelf/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mon Étagère - LootShelf{% endblock %}

{% block body %}
{# Ce conteneur va annuler le centrage de main-content et prendre toute la place #}
<div class="shelf-layout">
    
    {# --- 1. BARRE LATÉRALE (SIDEBAR) --- #}
    <aside id="sidebar" class="sidebar">
        <button id="toggle-sidebar" class="toggle-btn">
            <span class="arrow">◀</span>
        </button>
        
        <nav class="sidebar-nav">
            <div class="nav-item active">
                <span class="icon">🎮</span> <span>TOUS MES JEUX</span>
            </div>
            <div class="nav-item">
                <span class="icon">🔥</span> <span>EN COURS</span>
            </div>
            <div class="nav-item">
                <span class="icon">✅</span> <span>TERMINÉS</span>
            </div>
            <div class="nav-item">
                <span class="icon">⏳</span> <span>LISTE DE SOUHAITS</span>
            </div>
        </nav>
    </aside>

    {# --- 2. CONTENU PRINCIPAL --- #}
    <section class="shelf-main">
        
        <header class="shelf-page-header">
            <h1>MON ÉTAGÈRE</h1>
        </header>

        <div class="shelf-grid">
            <p style="color: rgba(255,255,255,0.5); font-family: 'Roboto';">
                VOTRE ÉTAGÈRE EST VIDE. COMMENCEZ PAR AJOUTER UN JEU !
            </p>
        </div>

        {# --- 3. BARRE DE RECHERCHE ET FILTRES (BAS) --- #}
        <footer class="shelf-controls">
            <div class="search-container">
                <input type="text" placeholder="RECHERCHER UN JEU..." class="pixel-input">
            </div>
            <div class="filters-container">
                <select class="pixel-select">
                    <option>TOUS LES STATUTS</option>
                    <option>EN COURS</option>
                    <option>TERMINÉ</option>
                </select>
            </div>
        </footer>

    </section>
</div>
{% endblock %}