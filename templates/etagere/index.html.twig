{# templates/shelf/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mon Étagère - LootShelf{% endblock %}

{% block body %}
<div class="shelf-layout">
    
    {# --- 1. SIDEBAR (À GAUCHE) --- #}
    <aside id="sidebar" class="sidebar">
        <button id="toggle-sidebar" class="toggle-btn">
            <span class="menu-icon">✕</span> {# Icône Burger par défaut #}
        </button>
        <nav class="sidebar-nav">
        <div class="nav-item active">
            <span class="label">Mon étagère</span>
        </div>
        <div class="nav-item">
            <span class="label">Recherche un collectionneur</span>
        </div>
        <div class="nav-item">
            <span class="label">Bibliothèque général</span>
        </div>
        <div class="nav-item">
            <span class="label">Paramètre</span>
        </div>
    </nav>
    </aside>

    {# --- 2. ZONE DE CONTENU (À DROITE) --- #}
    <section class="shelf-main">
        
        {# C'est ici qu'on met le titre de la page ! #}
        <header class="shelf-page-header">
            <h1>Mon étagère</h1>
            <button class="btn-neon btn-neon-orange rounded-3 px-4 py-2">
                + AJOUTER UN JEU
            </button>
        </header>

        {# Zone des jeux #}
        <div class="shelf-grid">
            <div class="empty-state-box">
                <h2>VOTRE ÉTAGÈRE EST VIDE</h2>
            </div>
        </div>

        {# Barre de contrôle basse #}
        {# --- 3. BARRE DE RECHERCHE ET FILTRES (BAS) --- #}
        <footer class="shelf-controls">
            <div class="search-container">
                <input type="text" placeholder="RECHERCHER UN JEU..." class="pixel-input">
            </div>
            
            {# 🚀 NOUVEAUX FILTRES EN LIGNE #}
            <div class="inline-filters">
                <button class="filter-btn active">TOUS</button>
                <button class="filter-btn">EN COURS</button>
                <button class="filter-btn">TERMINÉS</button>
                <button class="filter-btn">PLATINÉS</button>
            </div>
        </footer>

    </section>
</div>
{% endblock %}