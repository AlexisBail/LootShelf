{# templates/home/index.html.twig #}
{% extends 'base.html.twig' %}


{% block body %}
<section class="hero-section">
    
    <div class="welcome-text-container">
        <h1>BIENVENUE SUR LOOTSHELF !</h1>
        <h2>VOTRE ÉTAGÈRE VIRTUELLE POUR VOS JEUX</h2>
        
        <p class="texte-accueil">
            COLLECTIONNEZ, ORGANISEZ ET SUIVEZ VOTRE PROGRESSION DANS VOS JEUX PRÉFÉRÉS.<br>
            CRÉEZ VOTRE COMPTE POUR COMMENCER !
        </p>
    </div>

    <div class="chest-area">
        <img src="{{ asset('image/coffre_ferme.png') }}" alt="Coffre" class="pixelated main-chest">
    </div>

    <div id="loginModal" class="modal-overlay" style="display:none;">
        <div class="modal-container">
            <span class="close-modal">&times;</span>
        
            <form action="{{ path('app_login') }}" method="post">
                <h2 class="modal-title">CONNEXION</h2>
        
                <div class="input-wrapper">
                    <label>Email</label>
                    <input type="email" name="_username" class="input-pixel" placeholder="ton-mail@exemple.com" required autofocus>
                </div>

                <div class="input-wrapper" style="margin-top: 15px;">
                    <label>Mot de passe</label>
                    <input type="password" name="_password" class="input-pixel" placeholder="••••••••" required>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn-signin-neon">
                    SIGN IN
                </button>
        
                <div class="modal-footer">
                    <a href="#" class="link-forgot-pixel">Mot de passe oublié ?</a>
                </div>
            </form>
        </div>
    </div>

    <div class="cta-area">
        <a href="#" class="btn-neon btn-neon-green rounded-3 px-5 py-3">
            VOIR LES ÉTAGÈRES
        </a>
    </div>

</section>
{% endblock %}