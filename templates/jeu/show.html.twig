{% extends 'base.html.twig' %}

{% block title %}Jeu{% endblock %}

{% block body %}
    <h1>Jeu</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ jeu.id }}</td>
            </tr>
            <tr>
                <th>Titre</th>
                <td>{{ jeu.titre }}</td>
            </tr>
            <tr>
                <th>Image</th>
                <td>{{ jeu.image }}</td>
            </tr>
            <tr>
                <th>Developpeur</th>
                <td>{{ jeu.developpeur }}</td>
            </tr>
            <tr>
                <th>Editeur</th>
                <td>{{ jeu.editeur }}</td>
            </tr>
            <tr>
                <th>Genre</th>
                <td>{{ jeu.genre ? jeu.genre|json_encode : '' }}</td>
            </tr>
            <tr>
                <th>Plateform_disponible</th>
                <td>{{ jeu.plateformDisponible ? jeu.plateformDisponible|json_encode : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_jeu_index') }}">back to list</a>

    <a href="{{ path('app_jeu_edit', {'id': jeu.id}) }}">edit</a>

    {{ include('jeu/_delete_form.html.twig') }}
{% endblock %}
