{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}LootShelf{% endblock %}</title>
        <link rel="icon" href="{{ asset('favicon.ico') }}">
    
        {# 1. CSS de Bootstrap (CDN) #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

        {% block stylesheets %}
            {{ importmap('app') }}
        {% endblock %}

        {# 2. JS de Bootstrap (CDN) - Placé ICI pour être sûr qu'il charge avant tes clics #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" defer></script>

        {% block javascripts %}
        {% endblock %}
    </head>

    {# --- 1. LOGIQUE DU FOND DYNAMIQUE --- #}
    {% set current_route = app.request.attributes.get('_route') %}
    {% set outside_routes = ['app_home', 'app_register', 'app_login'] %}
    
    <body class="{% if current_route in outside_routes %}bg-outside{% else %}bg-inside{% endif %}">
        <div class="app-wrapper">
            
            {# --- 2. HEADER GLOBAL DYNAMIQUE --- #}
            <header class="head">
                <div class="logo-area">
                    <a href="{{ path('app_home') }}">
                        <img src="{{ asset('image/logo_lootshelf.png') }}" alt="LootShelf" class="pixelated" height="55">
                    </a>
                </div>
                
                {# Boutons header si connecter ou visiteur #}
                <nav class="nav-links">
                    {% if app.user %}
                        {# 🟢 AFFICHAGE SI CONNECTÉ (Pseudo + Menu Déroulant) #}
                        <div class="user-menu">
                            <span class="pseudo-text">{{ app.user.pseudo|upper }} ▼</span>
                            
                            <div class="dropdown-content">
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_admin_dashboard') }}" style="color: var(--neon-green) !important;">🛠️ DASHBOARD ADMIN</a>
                                <hr class="dropdown-divider">
                            {% endif %}

                                <a href="{{ path('app_etagere') }}">🎮 MON ÉTAGÈRE</a>
                                <a href="{{ path('app_logout') }}">🚪 DÉCONNEXION</a>
                            </div>
                        </div>
                    {% else %}
                        {# 🔴 AFFICHAGE SI VISITEUR (Boutons classiques) #}
                        <a href="{{ path('app_register') }}" class="btn-neon btn-neon-pink rounded-3 px-4 py-2">S'INSCRIRE</a>
                        <a href="{{ path('app_home') }}#login" id="login-trigger" class="btn-neon btn-neon-blue rounded-3 px-4 py-2">SE CONNECTER</a>
                    {% endif %}
                </nav>
            </header>

            {# --- 3. ZONE DE CONTENU (Injecté par les autres fichiers) --- #}
            <main class="main-content">
                {% block body %}{% endblock %}
            </main>

            {# --- 4. FOOTER GLOBAL --- #}
            <footer class="foot">
                <p class="text-foot">2026 LootShelf | Powered by Alexis BAIL</p>
            </footer>
        </div>

        {# --- 5. MODALE DE CONNEXION GLOBALE --- #}
        <div id="loginModal" class="modal-overlay" style="display:none;">
            <div class="modal-container">
                <span class="close-modal">&times;</span>
        
                <form action="{{ path('app_login') }}" method="post">
                    <h2 class="modal-title">CONNEXION</h2>
        
                    <div class="input-wrapper">
                        <label>Email</label>
                        <input type="email" name="email" class="input-pixel" placeholder="ton-mail@exemple.com" required autofocus>
                    </div>

                    <div class="input-wrapper" style="margin-top: 15px;">
                        <label>Mot de passe</label>
                        <input type="password" name="password" class="input-pixel" placeholder="••••••••" required>
                    </div>

                    <div class="terms-wrapper" style="margin-top: 15px; margin-bottom: 15px;">
                        <input type="checkbox" id="remember_me" name="_remember_me" checked>
                        <label for="remember_me" style="cursor: pointer;">SE SOUVENIR DE MOI</label>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                    <button type="submit" class="btn-signin-neon">
                        CONNEXION
                    </button>
        
                    <div class="modal-footer">
                        <a href="#" class="link-forgot-pixel">Mot de passe oublié ?</a>
                    </div>
                </form>
            </div>
        </div>
    </body>
</html>